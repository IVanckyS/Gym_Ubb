# =============================================================
# GymUBB — Variables de entorno
# Copia este archivo a .env y rellena los valores reales
# NUNCA subir .env a git
# =============================================================

# ---- Base de datos PostgreSQL ----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gym_ubb
DB_USER=gym_ubb_user
DB_PASSWORD=change_this_password

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# ---- JWT ----
# Generar con: openssl rand -hex 64
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_AUDIENCE=gym-ubb

# ---- Servidor ----
PORT=8080
RUNMODE=production

# ---- Cloudflare R2 (storage de imágenes) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=gym-ubb-assets
R2_PUBLIC_URL=

# ---- CORS (dominio del frontend web, si aplica) ----
ALLOWED_ORIGIN=https://gym.ubiobio.cl
